# Email capture (Resend) — optional.
#
# When these are unset, POST /api/subscribe validates the address and returns
# { ok: true, stored: false } (and logs a warning) — handy for local dev.
#
# To actually store subscribers:
#   1. Create a Resend account and an Audience (https://resend.com).
#   2. Copy this file to `.env.local` and fill in the values below.
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Public site URL — used for canonical tags, sitemap, robots, and OG metadata.
# e.g. https://yourdomain.com  (no trailing slash)
NEXT_PUBLIC_SITE_URL=
